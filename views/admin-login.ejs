<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>어드민 로그인 | PricePick</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,sans-serif;background:#f0f2f5;display:flex;align-items:center;justify-content:center;min-height:100vh}
    .card{background:#fff;border-radius:12px;padding:40px;width:100%;max-width:380px;box-shadow:0 4px 20px rgba(0,0,0,.1)}
    h1{font-size:1.5rem;margin-bottom:8px;color:#1a1a1a}
    p{color:#666;font-size:.9rem;margin-bottom:24px}
    label{display:block;font-size:.85rem;color:#444;margin-bottom:6px;font-weight:500}
    input{width:100%;padding:12px 16px;border:1.5px solid #ddd;border-radius:8px;font-size:1rem;outline:none}
    input:focus{border-color:#5b7eff}
    .error{background:#fff0f0;color:#d32f2f;padding:10px 14px;border-radius:8px;font-size:.85rem;margin-bottom:16px;border-left:3px solid #d32f2f}
    button{width:100%;padding:13px;background:#5b7eff;color:#fff;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer;margin-top:16px}
    button:hover{background:#4a6be8}
  </style>
</head>
<body>
  <div class="card">
    <h1>🔒 어드민 로그인</h1>
    <p>PricePick 관리자 전용 페이지</p>
    <% if (error) { %><div class="error">⚠️ <%= error %></div><% } %>
    <form method="POST" action="/admin/login">
      <label>비밀번호</label>
      <input type="password" name="password" placeholder="어드민 비밀번호 입력" autofocus required>
      <button type="submit">로그인</button>
    </form>
  </div>
</body>
</html>
